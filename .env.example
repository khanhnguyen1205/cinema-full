# === Client (Vite: import.meta.env) ===
# URL client gọi (qua Vite). Sao chép file này thành .env khi cần đổi.
# Data đi qua gateway phân quyền ở auth server, KHÔNG gọi json-server (:9999) trực tiếp.
VITE_API_URL=http://localhost:4000/api
VITE_AUTH_URL=http://localhost:4000

# === Database (Prisma → Neon Postgres) ===
# Pooled connection (host có "-pooler"). Runtime dùng cái này.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Direct connection (không "-pooler"). Dùng cho migrate/shadow DB.
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# === Server (auth + gateway, đọc qua dotenv) ===
# Vite bỏ qua các biến không có tiền tố VITE_, nên để chung một file .env là an toàn.
AUTH_PORT=4000
DATA_URL=http://localhost:9999
WEB_ORIGIN=http://localhost:3000
# Bí mật ký JWT. Dev có thể để trống (dùng mặc định). Production BẮT BUỘC đặt chuỗi ngẫu nhiên.
JWT_SECRET=cinema-dev-secret-change-me
# NODE_ENV=production sẽ chặn khởi động nếu JWT_SECRET còn là mặc định.
