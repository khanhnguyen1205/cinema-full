{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noFallthroughCasesInSwitch": true,

    "allowJs": true,
    "checkJs": false,

    "paths": {
      "components/*": ["./src/components/*"],
      "context/*": ["./src/context/*"],
      "hooks/*": ["./src/hooks/*"],
      "lib/*": ["./src/lib/*"],
      "pages/*": ["./src/pages/*"],
      "queries/*": ["./src/queries/*"],
      "routes/*": ["./src/routes/*"],
      "services/*": ["./src/services/*"],
      "styles/*": ["./src/styles/*"],
      "types": ["./src/types"],
      "types/*": ["./src/types/*"]
    }
  },
  "include": ["src"]
}
