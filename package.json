{
  "name": "cinema-app",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
