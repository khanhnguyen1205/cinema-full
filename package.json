{
  "name": "cinema-app",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/space-mono": "^5.2.9",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.101.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.9.2"
  },
  "scripts": {
    "start": "vite",
    "dev": "concurrently -n api,auth,web -c green,magenta,cyan \"npm:api\" \"npm:auth\" \"npm:start\"",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "api": "json-server --watch db.json --port 9999",
    "auth": "node server/auth-server.js",
    "hash-passwords": "node server/hash-passwords.js",
    "postinstall": "prisma generate --schema server/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema server/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema server/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema server/prisma/schema.prisma",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio --schema server/prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx server/prisma/seed.ts",
    "schema": "server/prisma/schema.prisma"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "happy-dom": "^20.10.6",
    "json-server": "^0.17.4",
    "prettier": "^3.9.5",
    "prisma": "^6.19.3",
    "tsx": "^4.23.1",
    "typescript": "~5.7",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
